---
import { Image } from "astro:assets";
import ImagePlaceholder from "./ImagePlaceholder.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  product: CollectionEntry<"products">;
  variant?: "compact" | "detailed";
}

const { product, variant = "compact" } = Astro.props;
const p = product.data;
---

<div class="bg-surface border border-border rounded-2xl overflow-hidden flex flex-col">
    {
        p.image ? (
          <Image
            src={p.image}
            alt={`${p.name} — forklift listrik ${p.general.ratedCapacity}`}
            widths={[360, 480, 720]}
            sizes="(min-width: 1024px) 360px, (min-width: 640px) 45vw, 100vw"
            class="w-full h-50 object-cover"
          />
        ) : (
          <ImagePlaceholder caption="Foto produk" class="w-full h-50" />
        )
      }
  <div class="p-6 flex flex-col flex-1">
    <div class="text-xs font-semibold text-text-secondary uppercase tracking-[0.04em] mb-2">{p.category}</div>
    <div class="font-heading font-bold text-[19px] text-navy mb-2.5">{p.name}</div>
    <p class="m-0 mb-4 text-sm leading-relaxed text-text-secondary">{p.tagline}</p>

    {
      variant === "detailed" && (
        <div class="flex flex-col gap-2 py-4 border-t border-b border-border mb-4.5">
          <div class="flex justify-between text-[13.5px]">
            <span class="text-text-secondary">Kapasitas</span>
            <span class="font-semibold text-text">{p.general.ratedCapacity}</span>
          </div>
          <div class="flex justify-between text-[13.5px]">
            <span class="text-text-secondary">Tinggi Angkat</span>
            <span class="font-semibold text-text">{p.dimensions.stdMaxLiftingHeight}</span>
          </div>
          <div class="flex justify-between text-[13.5px]">
            <span class="text-text-secondary">Baterai</span>
            <span class="font-semibold text-text">{p.performance.batteryVoltageCapacity}</span>
          </div>
          <div class="flex justify-between text-[13.5px]">
            <span class="text-text-secondary">Cocok Untuk</span>
            <span class="font-semibold text-text text-right">{p.useCase}</span>
          </div>
        </div>
      )
    }

    {
      variant === "detailed" ? (
        <a
          href={`/produk/${p.slug}/`}
          class="mt-auto inline-block text-center bg-navy text-white p-3 rounded-lg text-sm font-semibold hover:opacity-90"
        >
          Lihat Detail Produk
        </a>
      ) : (
        <a href={`/produk/${p.slug}/`} class="font-semibold text-sm">
          Lihat Detail →
        </a>
      )
    }
  </div>
</div>
